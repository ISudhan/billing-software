# Frontend Environment Variables — copy this file to .env and fill in values

# API base URL (used for making API requests from the frontend)
VITE_API_URL=http://localhost:5000/api

# App name shown in the UI
VITE_APP_NAME=Smart Energy Solutions

# App version
VITE_APP_VERSION=1.0.0

# Dev server port
VITE_PORT=3000

# Backend server URL (used by the Vite dev proxy)
VITE_BACKEND_URL=http://localhost:5000

# Backend health check endpoint (used to verify backend is running)
VITE_HEALTH_URL=http://localhost:5000/health
